# Airtable
VITE_AIRTABLE_TOKEN=
VITE_AIRTABLE_BASE_ID=

# Anthropic (server-side only — do NOT add a VITE_ prefix; that would inline
# the key into the client bundle. Used by api/*.js serverless functions and server.js.)
ANTHROPIC_API_KEY=

# GoAffPro
VITE_GOAFFPRO_TOKEN=

# Shopify — legacy custom-app token (read_orders)
# Used by sync-orders.js ONLY. Do not reuse for draft orders.
SHOPIFY_STORE=takingkare.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# Shopify — OAuth app ("kare-data-sync") for draft-order creator seeding
# Client ID / secret come from the Shopify Dev Dashboard.
# SHOPIFY_APP_URL is the public base URL that Shopify redirects back to
# (must match the Allowed redirection URL configured in the Dev Dashboard).
# SHOPIFY_SCOPES is optional — falls back to the default list in install.js.
# SHOPIFY_DRAFT_ORDER_TOKEN is populated AFTER a successful OAuth install
# (paste from Vercel function logs). Used by /api/send-product.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_APP_URL=https://app.takingkare.net
SHOPIFY_SCOPES=read_customers,write_customers,read_draft_orders,write_draft_orders,read_orders,write_orders
SHOPIFY_DRAFT_ORDER_TOKEN=

# PandaDoc
PANDADOC_API_KEY=
PANDADOC_BRIEF_TEMPLATE_ID=
PANDADOC_AGREEMENT_TEMPLATE_ID=
